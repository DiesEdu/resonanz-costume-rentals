# Copy this file to .env and adjust the URL to match your local PHP server.
#
# Option A – PHP built-in server (recommended for development)
#   cd backend && php -S localhost:8000 index.php
VITE_API_BASE=http://localhost:8000
#
# Option B – Apache + mod_rewrite
#   VITE_API_BASE=http://localhost/costume-rental/backend
